@model IEnumerable<Product>
@{
    ViewData["Title"] = "Home";
}

<section>
    <h1>Welcome to Marketeer</h1>
    <p>A demo marketplace built with ASP.NET Core MVC.</p>
</section>

<section>
    <h2>Featured Products</h2>
    <div class="grid">
        @foreach (var product in Model)
        {
            <article class="card">
                <h3>@product.Name</h3>
                <p>@product.Description</p>
                <p><strong>$@product.Price</strong></p>
                <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id">View details</a>
            </article>
        }
    </div>
</section>
