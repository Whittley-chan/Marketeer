@using System.Linq
@model IEnumerable<Order>
@{
    ViewData["Title"] = "My Orders";
}

<h1>My Orders</h1>

@if (!Model.Any())
{
    <p>You haven't placed any orders yet.</p>
    <a asp-controller="Product" asp-action="Index" class="btn">Start Shopping</a>
}
else
{
    <div class="grid orders-grid">
        @foreach (var order in Model)
        {
            <div class="card order-card">

                <div class="order-header">
                    <h3>Order #@order.Id</h3>
                    <span class="status">@order.DeliveryStatus</span>
                </div>

                <div class="order-info">
                    <p><strong>Customer:</strong> @order.CustomerName</p>
                    <p><strong>Address:</strong> @order.ShippingAddress</p>
                    <p><strong>Date:</strong> @order.CreatedAtUtc.ToLocalTime().ToString("g")</p>
                </div>

                <div class="order-total">
                    Total: <strong>$@order.Total.ToString("F2")</strong>
                </div>

                <div class="order-items">
                    <h4>Items</h4>
                    <ul>
                        @foreach (var item in order.Items.OrderBy(i => i.ProductName))
                        {   
                            <li>
                                <span>@item.ProductName</span>
                                <span>@item.Quantity x $@item.LineTotal.ToString("F2")</span>
                            </li>
                        }
                    </ul>
                </div>

                <a asp-action="Success" asp-route-id="@order.Id" class="btn">
                    View Details
                </a>

            </div>
        }
    </div>
}