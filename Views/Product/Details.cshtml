@model Product
@{
    ViewData["Title"] = "Product Details";
}

<div class="product-card">
    <h1>@Model.Name</h1>
    <p class="desc">@Model.Description</p>

    <div class="product-info">
        <p><span>Category:</span> @Model.Category?.Name</p>
        <p><span>Price:</span> $@Model.Price</p>
        <p><span>Rating:</span> @Model.AverageRating.ToString("0.0") / 5 (@Model.Reviews.Count review(s))</p>
        <p><span>Stock:</span> @Model.AvailableQuantity available | @Model.ReservedQuantity reserved</p>
    </div>

    <form id="addToCartForm" asp-controller="Cart" asp-action="Add" method="post" class="inline-form">
        <input type="hidden" name="productId" value="@Model.Id" />

        <input id="quantity"
               type="number"
               name="quantity"
               min="1"
               max="@Model.AvailableQuantity"
               value="1" />

        <button type="submit">Add to Cart</button>
    </form>
</div>

<div id="popupMessage" class="popup-message" style="display: none;"></div>

<div class="card">
    <h2>Ratings & Comments</h2>

    <form asp-action="AddReview" method="post" class="stacked-form">
        <input type="hidden" name="productId" value="@Model.Id" />

        <div>
            <label for="rating">Rating</label>
            <select id="rating" name="rating" required>
                <option value="5">⭐⭐⭐⭐⭐ - Excellent</option>
                <option value="4">⭐⭐⭐⭐ - Good</option>
                <option value="3">⭐⭐⭐ - Average</option>
                <option value="2">⭐⭐ - Poor</option>
                <option value="1">⭐ - Bad</option>
            </select>
        </div>

        <div>
            <label for="comment">Comment</label>
            <textarea id="comment" name="comment" rows="3" required></textarea>
        </div>

        <button type="submit">Submit Review</button>
    </form>

    @if (Model.Reviews.Any())
    {
        <div class="review-list">
            @foreach (var review in Model.Reviews.OrderByDescending(r => r.CreatedAtUtc))
            {
                <div class="review-item">
                    <div class="review-header">
                        <strong>@review.Rating/5</strong>
                        <span>@review.UserId</span>
                    </div>
                    <p>@review.Comment</p>
                </div>
            }
        </div>
    }
    else
    {
        <p>No reviews yet.</p>
    }
</div>