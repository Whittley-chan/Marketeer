@model AdminProductViewModel
@{
    ViewData["Title"] = "Admin - Edit Product";
    var categories = ViewBag.Categories as IEnumerable<Category> ?? Enumerable.Empty<Category>();
}

<h1>Edit Product</h1>

<form asp-action="EditProduct" method="post" class="stacked-form">
    <input asp-for="Id" type="hidden" />
    <div>
        <label asp-for="Name"></label>
        <input asp-for="Name" />
    </div>
    <div>
        <label asp-for="Description"></label>
        <textarea asp-for="Description" rows="3"></textarea>
    </div>
    <div>
        <label asp-for="Price"></label>
        <input asp-for="Price" type="number" step="0.01" />
    </div>
    <div>
        <label asp-for="ImageUrl"></label>
        <input asp-for="ImageUrl" />
    </div>
    <div>
        <label asp-for="CategoryId">Category</label>
        <select asp-for="CategoryId">
            @foreach (var category in categories)
            {
                <option value="@category.Id">@category.Name</option>
            }
        </select>
    </div>
    <div>
        <label asp-for="AvailableQuantity"></label>
        <input asp-for="AvailableQuantity" type="number" />
    </div>
    <div>
        <label asp-for="ReservedQuantity"></label>
        <input asp-for="ReservedQuantity" type="number" />
    </div>
    <button type="submit">Save</button>
</form>
